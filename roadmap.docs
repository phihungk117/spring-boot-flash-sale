// k6 load test script
import http from 'k6/http';
import { check } from 'k6';

export let options = {
    vus: 500,        // 500 virtual users
    duration: '30s',
};

export default function() {
    let response = http.post(
        'http://localhost:8080/api/v1/bookings/events/1',
        JSON.stringify({ quantity: 1 }),
        { headers: {
            'Content-Type': 'application/json',
            'Authorization': `Bearer ${__ENV.TOKEN}`,
            'Idempotency-Key': `${__VU}-${__ITER}` // ← MỖI request có key riêng
        }}
    );

    check(response, {
        'status is 202 or 409': (r) => r.status === 202 || r.status === 409,
        'status is not 429':    (r) => r.status !== 429,  // không bị rate limit bất ngờ
        'response time < 500ms':(r) => r.timings.duration < 500,
    });
}
