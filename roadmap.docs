2.5 Booking Service — Luồng chính
java
@Service
@RequiredArgsConstructor
@Slf4j
public class BookingService {

    private final InventoryService inventoryService;
    private final RabbitTemplate rabbitTemplate;
    private final BookingMetrics bookingMetrics;

    @Transactional
    public BookingResponse book(Long eventId, Long userId, BookingRequest request) {

        // Bước 1: Atomic check & deduct inventory trong Redis
        DeductResult result = inventoryService.deductInventory(
            eventId, userId, request.getQuantity());

        if (result != DeductResult.SUCCESS) {
            bookingMetrics.recordBookingFailed(eventId, result.name());
            throw switch (result) {
                case SOLD_OUT        -> new InsufficientInventoryException("Hết vé!");
                case ALREADY_BOOKED  -> new DuplicateBookingException("Bạn đã đặt vé này rồi!");
                default              -> new RuntimeException("Lỗi hệ thống");
            };
        }

        // Bước 2: Tạo order message và đẩy vào RabbitMQ
        String orderCode = UUID.randomUUID().toString();
        OrderMessage orderMessage = OrderMessage.builder()
            .orderCode(orderCode)
            .eventId(eventId)
            .userId(userId)
            .quantity(request.getQuantity())
            .timestamp(Instant.now())
            .build();

        try {
            rabbitTemplate.convertAndSend(
                RabbitMQConfig.ORDER_EXCHANGE,
                RabbitMQConfig.ORDER_ROUTING_KEY,
                orderMessage);
        } catch (Exception e) {
            // Nếu enqueue thất bại → rollback inventory
            log.error("Failed to enqueue order, rolling back inventory", e);
            inventoryService.rollbackInventory(eventId, userId, request.getQuantity());
            throw new RuntimeException("Không thể xử lý đặt vé, vui lòng thử lại");
        }

        bookingMetrics.recordBookingSuccess(eventId);

        // Bước 3: Trả về response ngay (không chờ DB write)
        return BookingResponse.builder()
            .orderCode(orderCode)
            .status("PROCESSING")
            .message("Đặt vé thành công! Vui lòng thanh toán trong 15 phút.")
            .expiresAt(LocalDateTime.now().plusMinutes(15))
            .build();
    }
}
________________________________________
2.6 Order Consumer — Xử lý bất đồng bộ
java
@Component
@RequiredArgsConstructor
@Slf4j
public class OrderConsumer {

    private final OrderRepository orderRepository;
    private final EventRepository eventRepository;
    private final RabbitTemplate rabbitTemplate;

    @RabbitListener(queues = RabbitMQConfig.ORDER_QUEUE)
    public void processOrder(OrderMessage message) {
        log.info("Processing order: {}", message.getOrderCode());
        try {
            Event event = eventRepository.findById(message.getEventId())
                .orElseThrow(() -> new RuntimeException("Event not found"));

            Order order = Order.builder()
                .orderCode(message.getOrderCode())
                .userId(message.getUserId())
                .event(event)
                .quantity(message.getQuantity())
                .unitPrice(event.getPrice())
                .totalAmount(event.getPrice().multiply(BigDecimal.valueOf(message.getQuantity())))
                .status(OrderStatus.PENDING)
                .expiresAt(LocalDateTime.now().plusMinutes(15))
                .build();

            orderRepository.save(order);

            // Đẩy vào Delayed Queue để auto-cancel sau 15 phút
            CancelMessage cancelMessage = new CancelMessage(
                message.getOrderCode(), message.getEventId(),
                message.getUserId(), message.getQuantity());

            rabbitTemplate.convertAndSend(
                RabbitMQConfig.DELAY_EXCHANGE,
                RabbitMQConfig.DELAY_ROUTING_KEY,
                cancelMessage);

            log.info("Order {} saved to DB, cancel scheduled", message.getOrderCode());

        } catch (Exception e) {
            log.error("Failed to process order {}: {}", message.getOrderCode(), e.getMessage());
            throw new AmqpRejectAndDontRequeueException("Order processing failed", e);
        }
    }
}
________________________________________
2.7 Auto-Cancel Consumer (Delayed Queue)
java
@Component
@RequiredArgsConstructor
@Slf4j
public class DelayedOrderConsumer {

    private final OrderRepository orderRepository;
    private final InventoryService inventoryService;

    @RabbitListener(queues = "order.cancel.queue")
    public void processCancelOrder(CancelMessage message) {
        log.info("Auto-cancel check for order: {}", message.getOrderCode());

        orderRepository.findByOrderCode(message.getOrderCode())
            .ifPresent(order -> {
                if (order.getStatus() == OrderStatus.PENDING) {
                    order.setStatus(OrderStatus.EXPIRED);
                    order.setCancelledAt(LocalDateTime.now());
                    order.setCancelReason("Hết thời gian thanh toán (15 phút)");
                    orderRepository.save(order);

                    // Nhả vé lại vào kho
                    inventoryService.rollbackInventory(
                        message.getEventId(),
                        message.getUserId(),
                        message.getQuantity());

                    log.info("Order {} expired and rolled back", message.getOrderCode());
                } else {
                    // QUAN TRỌNG: Nếu đã PAID thì không làm gì cả
                    log.info("Order {} already processed (status: {}), skip cancel",
                        message.getOrderCode(), order.getStatus());
                }
            });
    }
}
________________________________________
2.8 Reconciliation Service ← MỚI
Mục tiêu: Phòng trường hợp app crash giữa chừng làm lệch dữ liệu giữa Redis và PostgreSQL.
java
@Service
@RequiredArgsConstructor
@Slf4j
public class ReconciliationService {

    private final EventRepository eventRepository;
    private final OrderRepository orderRepository;
    private final InventoryService inventoryService;

    // Chạy mỗi 5 phút
    @Scheduled(fixedDelay = 300_000)
    public void reconcileInventory() {
        log.info("Starting inventory reconciliation...");

        List<Event> activeEvents = eventRepository.findByStatus("ACTIVE");

        for (Event event : activeEvents) {
            int redisInventory = inventoryService.getCurrentInventory(event.getId());

            // Tính inventory thực tế từ DB
            int pendingOrPaidCount = orderRepository
                .countByEventIdAndStatusIn(event.getId(),
                    List.of(OrderStatus.PENDING, OrderStatus.PAID));
            int dbInventory = event.getTotalQuantity() - pendingOrPaidCount;

            if (redisInventory != dbInventory) {
                log.warn("Inventory mismatch for event {}: Redis={}, DB={}. Fixing...",
                    event.getId(), redisInventory, dbInventory);

                // Lấy DB làm source of truth
                inventoryService.forceSetInventory(event.getId(), dbInventory);
            }
        }

        log.info("Reconciliation completed.");
    }
}
```

---

### PHASE 3: DISTRIBUTED LOCK — PAYMENT (Tuần 3)

#### 3.1 Vai trò của Distributed Lock

Lua script đã xử lý concurrent inventory deduct hoàn toàn. Distributed Lock ở tầng này **không** bảo vệ inventory mà bảo vệ **idempotency của thanh toán** — tránh double payment khi user bấm nút Pay nhiều lần cùng lúc:
```
User bấm Pay → acquire lock(orderId) → process payment → release lock
User bấm Pay lần 2 (double click) → try acquire lock → FAILED → "đang xử lý"
3.2 Payment Service với Redisson Lock
java
@Service
@RequiredArgsConstructor
@Slf4j
public class PaymentService {

    private final RedissonClient redissonClient;
    private final OrderRepository orderRepository;

    private static final String PAYMENT_LOCK_PREFIX = "lock:payment:order:";
    private static final int LOCK_WAIT_TIME  = 3;  // giây
    private static final int LOCK_LEASE_TIME = 10; // giây

    public PaymentResponse processPayment(String orderCode, Long userId, PaymentRequest request) {
        String lockKey = PAYMENT_LOCK_PREFIX + orderCode;
        RLock lock = redissonClient.getLock(lockKey);

        try {
            boolean acquired = lock.tryLock(LOCK_WAIT_TIME, LOCK_LEASE_TIME, TimeUnit.SECONDS);
            if (!acquired) {
                return PaymentResponse.failed("Đơn hàng đang được xử lý, vui lòng chờ.");
            }
            return executePayment(orderCode, userId, request);

        } catch (InterruptedException e) {
            Thread.currentThread().interrupt();
            throw new RuntimeException("Payment interrupted");
        } finally {
            if (lock.isHeldByCurrentThread()) {
                lock.unlock();
            }
        }
    }

    @Transactional
    private PaymentResponse executePayment(String orderCode, Long userId, PaymentRequest request) {
        Order order = orderRepository.findByOrderCode(orderCode)
            .orElseThrow(() -> new OrderNotFoundException("Order not found: " + orderCode));

        if (!order.getUserId().equals(userId))
            throw new UnauthorizedException("Không có quyền thanh toán đơn này");

        if (order.getStatus() != OrderStatus.PENDING)
            throw new InvalidOrderStatusException("Đơn hàng không thể thanh toán. Trạng thái: " + order.getStatus());

        if (LocalDateTime.now().isAfter(order.getExpiresAt()))
            throw new OrderExpiredException("Đơn hàng đã hết hạn thanh toán");

        boolean paymentSuccess = mockPaymentGateway(request);
        if (paymentSuccess) {
            order.setStatus(OrderStatus.PAID);
            order.setPaidAt(LocalDateTime.now());
            orderRepository.save(order);
            return PaymentResponse.success("Thanh toán thành công!", order.getTotalAmount());
        } else {
            return PaymentResponse.failed("Thanh toán thất bại, vui lòng thử lại.");
        }
    }

    private boolean mockPaymentGateway(PaymentRequest request) {
        // Mock: luôn thành công — thực tế gọi VNPay/Stripe/etc.
        return true;
    }
}
