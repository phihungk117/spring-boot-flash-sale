PHASE 4: API CONTROLLERS & SECURITY (Tuần 4)
4.1 BookingController (đầy đủ)
java
@RestController
@RequestMapping("/api/v1/bookings")
@RequiredArgsConstructor
public class BookingController {

    private final BookingService bookingService;
    private final OrderService orderService;
    private final PaymentService paymentService;
    private final IdempotencyService idempotencyService;
    private final ObjectMapper objectMapper;

    // POST /api/v1/bookings/events/{eventId}
    @PostMapping("/events/{eventId}")
    public ResponseEntity<ApiResponse<BookingResponse>> book(
            @PathVariable Long eventId,
            @RequestBody @Valid BookingRequest request,
            @RequestHeader(value = "Idempotency-Key", required = false) String idempotencyKey,
            @AuthenticationPrincipal UserDetails userDetails) throws JsonProcessingException {

        Long userId = ((CustomUserDetails) userDetails).getId();

        if (idempotencyKey != null) {
            Optional<String> existing = idempotencyService.getExistingResponse(idempotencyKey);
            if (existing.isPresent() && !existing.get().equals("PROCESSING")) {
                BookingResponse cached = objectMapper.readValue(existing.get(), BookingResponse.class);
                return ResponseEntity.accepted().body(ApiResponse.success(cached));
            }
            idempotencyService.trySetKey(idempotencyKey, "PROCESSING");
        }

        BookingResponse response = bookingService.book(eventId, userId, request);

        if (idempotencyKey != null) {
            idempotencyService.saveResponse(idempotencyKey, objectMapper.writeValueAsString(response));
        }

        return ResponseEntity.accepted().body(ApiResponse.success(response));
    }

    // POST /api/v1/bookings/orders/{orderCode}/pay
    @PostMapping("/orders/{orderCode}/pay")
    public ResponseEntity<ApiResponse<PaymentResponse>> pay(
            @PathVariable String orderCode,
            @RequestBody @Valid PaymentRequest request,
            @AuthenticationPrincipal UserDetails userDetails) {

        Long userId = ((CustomUserDetails) userDetails).getId();
        PaymentResponse response = paymentService.processPayment(orderCode, userId, request);
        return ResponseEntity.ok(ApiResponse.success(response));
    }

    // GET /api/v1/bookings/orders/{orderCode}
    @GetMapping("/orders/{orderCode}")
    public ResponseEntity<ApiResponse<OrderResponse>> getOrder(
            @PathVariable String orderCode,
            @AuthenticationPrincipal UserDetails userDetails) {

        Long userId = ((CustomUserDetails) userDetails).getId();
        OrderResponse response = orderService.getOrder(orderCode, userId);
        return ResponseEntity.ok(ApiResponse.success(response));
    }

    // GET /api/v1/bookings/orders/my
    @GetMapping("/orders/my")
    public ResponseEntity<ApiResponse<Page<OrderResponse>>> getMyOrders(
            @AuthenticationPrincipal UserDetails userDetails,
            Pageable pageable) {

        Long userId = ((CustomUserDetails) userDetails).getId();
        Page<OrderResponse> orders = orderService.getOrdersByUser(userId, pageable);
        return ResponseEntity.ok(ApiResponse.success(orders));
    }
}
