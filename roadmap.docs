2.2 Idempotency Service ← MỚI
Mục tiêu: Chống trường hợp client timeout rồi retry, tạo ra 2 order cho cùng 1 request.
java
@Service
@RequiredArgsConstructor
public class IdempotencyService {

    private final StringRedisTemplate redisTemplate;
    private static final String IDEMPOTENCY_KEY_PREFIX = "idempotency:";
    private static final Duration TTL = Duration.ofHours(24);

    // Kiểm tra key đã tồn tại chưa, nếu chưa thì set (atomic)
    public boolean trySetKey(String key, String placeholder) {
        Boolean isNew = redisTemplate.opsForValue()
            .setIfAbsent(IDEMPOTENCY_KEY_PREFIX + key, placeholder, TTL);
        return Boolean.TRUE.equals(isNew);
    }

    // Lưu response thực tế sau khi xử lý xong
    public void saveResponse(String key, String responseJson) {
        redisTemplate.opsForValue()
            .set(IDEMPOTENCY_KEY_PREFIX + key, responseJson, TTL);
    }

    // Lấy response cũ nếu key đã tồn tại
    public Optional<String> getExistingResponse(String key) {
        String val = redisTemplate.opsForValue().get(IDEMPOTENCY_KEY_PREFIX + key);
        return Optional.ofNullable(val);
    }
}
Cách dùng trong BookingController:
java
@PostMapping("/events/{eventId}")
public ResponseEntity<ApiResponse<BookingResponse>> book(
        @PathVariable Long eventId,
        @RequestBody @Valid BookingRequest request,
        @RequestHeader(value = "Idempotency-Key", required = false) String idempotencyKey,
        @AuthenticationPrincipal UserDetails userDetails) {

    Long userId = ((CustomUserDetails) userDetails).getId();

    // Nếu có idempotency key, check cache trước
    if (idempotencyKey != null) {
        Optional<String> existing = idempotencyService.getExistingResponse(idempotencyKey);
        if (existing.isPresent() && !existing.get().equals("PROCESSING")) {
            BookingResponse cached = objectMapper.readValue(existing.get(), BookingResponse.class);
            return ResponseEntity.accepted().body(ApiResponse.success(cached));
        }
        // Đánh dấu đang xử lý
        idempotencyService.trySetKey(idempotencyKey, "PROCESSING");
    }

    BookingResponse response = bookingService.book(eventId, userId, request);

    // Lưu response vào cache
    if (idempotencyKey != null) {
        idempotencyService.saveResponse(idempotencyKey, objectMapper.writeValueAsString(response));
    }

    return ResponseEntity.accepted().body(ApiResponse.success(response));
}
