2.3 Rate Limiting với Redis Lua Script ← MỚI
Mục tiêu: Giới hạn mỗi user chỉ được gọi booking API tối đa N lần/phút, chặn bot/attacker.
Lua Script — Token Bucket:
lua
-- scripts/rate_limit.lua
-- KEYS[1] = rate limit key (vd: "rate:user:123:booking")
-- ARGV[1] = max requests
-- ARGV[2] = window seconds

local current = redis.call('INCR', KEYS[1])
if current == 1 then
    redis.call('EXPIRE', KEYS[1], ARGV[2])
end
if current > tonumber(ARGV[1]) then
    return 0  -- Bị chặn
end
return 1  -- Cho qua
RateLimitFilter.java:
java
@Component
@RequiredArgsConstructor
@Slf4j
public class RateLimitFilter extends OncePerRequestFilter {

    private final StringRedisTemplate redisTemplate;

    private static final int MAX_REQUESTS = 10;   // tối đa 10 lần
    private static final int WINDOW_SECONDS = 60; // trong 60 giây

    @Override
    protected void doFilterInternal(HttpServletRequest request,
                                    HttpServletResponse response,
                                    FilterChain chain)
            throws ServletException, IOException {

        // Chỉ apply cho booking API
        if (!request.getRequestURI().contains("/bookings/events/")) {
            chain.doFilter(request, response);
            return;
        }

        String userId = extractUserIdFromToken(request);
        if (userId == null) {
            chain.doFilter(request, response);
            return;
        }

        String key = "rate:user:" + userId + ":booking";
        DefaultRedisScript<Long> script = new DefaultRedisScript<>();
        script.setScriptSource(new ResourceScriptSource(
            new ClassPathResource("scripts/rate_limit.lua")));
        script.setResultType(Long.class);

        Long result = redisTemplate.execute(script,
            List.of(key),
            String.valueOf(MAX_REQUESTS),
            String.valueOf(WINDOW_SECONDS));

        if (result == null || result == 0) {
            response.setStatus(HttpStatus.TOO_MANY_REQUESTS.value());
            response.setContentType("application/json");
            response.getWriter().write(
                "{\"success\":false,\"message\":\"Quá nhiều yêu cầu, vui lòng thử lại sau.\"}");
            return;
        }

        chain.doFilter(request, response);
    }

    private String extractUserIdFromToken(HttpServletRequest request) {
        // Parse JWT từ Authorization header
        // ...
        return null; // implement theo JWT logic của bạn
    }
}
