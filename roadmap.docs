@Component
@RequiredArgsConstructor
public class BookingMetrics {

    private final MeterRegistry meterRegistry;

    public void recordBookingSuccess(Long eventId) {
        meterRegistry.counter("booking.success", "eventId", eventId.toString()).increment();
    }

    public void recordBookingFailed(Long eventId, String reason) {
        meterRegistry.counter("booking.failed",
            "eventId", eventId.toString(),
            "reason", reason).increment();
    }

    public void recordInventoryLevel(Long eventId, int level) {
        meterRegistry.gauge("inventory.level",
            Tags.of("eventId", eventId.toString()), level);
    }

