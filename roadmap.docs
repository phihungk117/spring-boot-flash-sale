5.2 Integration Tests
java
@SpringBootTest
@Testcontainers
class BookingIntegrationTest {

    @Container
    static PostgreSQLContainer<?> postgres = new PostgreSQLContainer<>("postgres:15");

    @Container
    static GenericContainer<?> redis = new GenericContainer<>("redis:7-alpine")
        .withExposedPorts(6379);

    @Test
    void concurrentBooking_shouldNotOversell() throws InterruptedException {
        int totalTickets = 100;
        int totalUsers   = 500;

        ExecutorService executor = Executors.newFixedThreadPool(50);
        CountDownLatch latch = new CountDownLatch(totalUsers);
        AtomicInteger successCount = new AtomicInteger(0);
        AtomicInteger failCount    = new AtomicInteger(0);

        for (int i = 0; i < totalUsers; i++) {
            final int userId = i;
            executor.submit(() -> {
                try {
                    bookingService.book(eventId, (long) userId, request);
                    successCount.incrementAndGet();
                } catch (InsufficientInventoryException e) {
                    failCount.incrementAndGet();
                } finally {
                    latch.countDown();
                }
            });
        }

        latch.await(30, TimeUnit.SECONDS);

        assertEquals(totalTickets, successCount.get());
        assertEquals(totalUsers - totalTickets, failCount.get());
        assertEquals(0, inventoryService.getCurrentInventory(eventId));
    }

    // ← MỚI
    @Test
    void sameIdempotencyKey_shouldReturnSameResponse() {
        String idempotencyKey = UUID.randomUUID().toString();
        BookingResponse first  = bookingService.book(eventId, userId, request); // lần 1
        BookingResponse second = bookingService.book(eventId, userId, request); // lần 2 (retry)
        assertEquals(first.getOrderCode(), second.getOrderCode());
    }
}
